#!/bin/sh
# postinst -- configure proxmox-redfish. No venv/pip/network: the app runs on the
# system python3 with apt-provided requests/cryptography + bundled pure-Python deps.
set -e

ETC=/etc/proxmox-redfish
STATE=/var/lib/proxmox-redfish

case "$1" in
    configure)
        # Runtime directories. The daemon runs as root; lock these to root only
        # (0750) so secureboot state, sidecars, and varstore images are not world- or
        # group-readable.
        mkdir -p "$STATE/secureboot" "$STATE/varstores"
        chown root:root "$STATE" "$STATE/secureboot" "$STATE/varstores" 2>/dev/null || true
        chmod 0750 "$STATE" "$STATE/secureboot" "$STATE/varstores"
        mkdir -p "$ETC"
        chmod 0750 "$ETC" 2>/dev/null || true

        # Ship the SecureBoot profile catalog example if no live one exists.
        if [ ! -f "$ETC/secureboot_profiles.json" ] && \
           [ -f /opt/proxmox-redfish/config/secureboot_profiles.json.example ]; then
            cp /opt/proxmox-redfish/config/secureboot_profiles.json.example "$ETC/secureboot_profiles.json"
        fi

        # TLS: by default the daemon uses the Proxmox node certificate
        # (/etc/pve/local/pve-ssl.pem) -- same identity as the :8006 API -- so no cert
        # is generated here. On a non-PVE host with no cert, the daemon falls back to
        # plain HTTP (logged). Set REDFISH_USE_TLS=false in params.env to force HTTP.
        #
        # params.env holds PROXMOX_PASSWORD and Loki credentials: make it root-only
        # (0600), never group/world readable.
        chown root:root "$ETC/params.env" 2>/dev/null || true
        chmod 0600 "$ETC/params.env" 2>/dev/null || true
        # If an admin placed a TLS private key under $ETC, lock it down too.
        for keyf in "$ETC"/*.key; do
            [ -f "$keyf" ] && chmod 0600 "$keyf" 2>/dev/null || true
        done

        # Sanity-check that the app imports on the system interpreter.
        if ! PYTHONPATH=/opt/proxmox-redfish/src:/opt/proxmox-redfish/vendor \
                /usr/bin/python3 -c "import proxmox_redfish.proxmox_redfish" >/dev/null 2>&1; then
            echo "proxmox-redfish: WARNING - import check failed; verify python3-requests is installed." >&2
        fi

        # Enable (but do not start -- the admin must set credentials first).
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload || true
            systemctl enable proxmox-redfish.service >/dev/null 2>&1 || true
        fi

        echo "proxmox-redfish installed."
        echo "  1. Edit ${ETC}/params.env (set PROXMOX_HOST/USER/PASSWORD)."
        echo "  2. systemctl start proxmox-redfish"
        echo "  Endpoint: https://<host>:8443/redfish/v1"
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
esac

exit 0
