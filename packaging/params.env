# proxmox-redfish runtime configuration (installed to /etc/proxmox-redfish/params.env).
# Edit, then: systemctl restart proxmox-redfish

# --- Proxmox API ---
PROXMOX_HOST="127.0.0.1"
PROXMOX_USER="root@pam"
PROXMOX_PASSWORD="CHANGE_ME"
PROXMOX_NODE="pve"
PROXMOX_API_PORT="8006"
VERIFY_SSL="false"
PROXMOX_ISO_STORAGE="local"

# --- TLS for the Redfish endpoint ---------------------------------------------
# TLS is OPTIONAL. Set REDFISH_USE_TLS="false" to serve plain HTTP (e.g. behind a
# reverse proxy). When true (default) the daemon auto-resolves a certificate:
#   1. SSL_CERT_FILE + SSL_KEY_FILE below (if both set and exist)
#   2. Proxmox custom cert  /etc/pve/local/pveproxy-ssl.{pem,key}
#   3. Proxmox node cert    /etc/pve/local/pve-ssl.{pem,key}   <- same as the :8006 API
# Leave SSL_CERT_FILE empty to use the Proxmox node cert (recommended on a PVE host).
REDFISH_USE_TLS="true"
SSL_CERT_FILE=""
SSL_KEY_FILE=""
SSL_CA_FILE="/etc/proxmox-redfish/ca.crt"

# --- Logging ---
REDFISH_LOG_LEVEL="INFO"
REDFISH_LOGGING_ENABLED="true"

# --- SecureBoot (host-side OVMF varstore enrollment; runs as root on the PVE host) ---
REDFISH_SB_PROFILES="/etc/proxmox-redfish/secureboot_profiles.json"
REDFISH_SB_VARSTORE_DIR="/var/lib/proxmox-redfish/varstores"
REDFISH_SB_STATE_DIR="/var/lib/proxmox-redfish/secureboot"
REDFISH_SB_VG_ALLOWLIST="pve"
# SAFETY: writes are DRY-RUN until this is set to 1.
REDFISH_SB_ALLOW_WRITE="0"
REDFISH_SB_ALLOW_AUTOSTOP="0"
REDFISH_SB_BLANK_TEMPLATE="/var/lib/proxmox-redfish/varstores/OVMF_VARS_4M.blank.fd"
REDFISH_SB_OWNER_GUID="00000000-0000-0000-0000-000000000000"

# --- UEFI efidisk auto-provision on FirmwareMode=UEFI ---
REDFISH_AUTO_EFIDISK="1"
REDFISH_EFIDISK_STORAGE="local-lvm"

# --- Remote logging to Grafana Loki (OS-independent; empty URL disables) ---
REDFISH_LOKI_URL=""
REDFISH_LOKI_LABELS="job=proxmox-redfish"
REDFISH_LOKI_USER=""
REDFISH_LOKI_PASSWORD=""
REDFISH_LOKI_TENANT=""
REDFISH_LOKI_VERIFY="true"

# --- Protocol strictness: 0 = lenient (default), 1 = strict DSP0266 ---
REDFISH_STRICT_PROTOCOL="0"

# Serial console capture into Redfish LogServices/SerialLog is ON by default and
# starts lazily per VM on first request. Set REDFISH_SERIAL_CAPTURE=0 to disable
# (frees the QEMU serial socket for an interactive `qm terminal`).
REDFISH_SERIAL_MAX_LINES="2000"
