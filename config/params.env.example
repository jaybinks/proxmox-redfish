# Proxmox Configuration
export PROXMOX_HOST="192.168.1.55"
export PROXMOX_USER="YOUR_PAM_USER@pam"
export PROXMOX_PASSWORD="YOUR_PAM_USER_PASSWORD_HERE"
export PROXMOX_NODE="pve"
export PROXMOX_ISO_STORAGE="local"

# SSL Configuration (optional - uses defaults if not set)
export SSL_CERT_FILE="/opt/proxmox-redfish/config/ssl/server.crt"
export SSL_KEY_FILE="/opt/proxmox-redfish/config/ssl/server.key"
export SSL_CA_FILE="/opt/proxmox-redfish/config/ssl/ca.crt"

# Logging Configuration
export REDFISH_LOG_LEVEL="INFO"
export REDFISH_LOGGING_ENABLED="true"

# SSL Verification (for Proxmox API)
export VERIFY_SSL="false"

# --- SecureBoot management (host-side OVMF varstore enrollment) --------------
# The daemon must run ON the Proxmox host as root for these to work.
# Profile catalog: maps profile names -> pre-baked OVMF varstore images.
export REDFISH_SB_PROFILES="/opt/proxmox-redfish/config/secureboot_profiles.json"
# Allowlisted directory the varstore images MUST live under (INV-10).
export REDFISH_SB_VARSTORE_DIR="/opt/proxmox-redfish/varstores"
# Per-VM sidecar state + lock directory.
export REDFISH_SB_STATE_DIR="/var/lib/proxmox-redfish/secureboot"
# LVM volume groups whose block devices may be written (comma-separated).
export REDFISH_SB_VG_ALLOWLIST="pve"
# SAFETY: writes are DRY-RUN by default. Set to 1 to allow real dd writes.
export REDFISH_SB_ALLOW_WRITE="0"
# Allow the daemon to stop a running VM before enrolling (then restart it).
export REDFISH_SB_ALLOW_AUTOSTOP="0"

# Example: enable Secure Boot on VM 3009 via the standard Redfish API:
# curl -k -X PATCH -u "${REDFISH_USER}:${REDFISH_PASS}" \
#   -H "Content-Type: application/json" \
#   -d '{"SecureBootEnable": true}' \
#   "${REDFISH_BASEURL}/redfish/v1/Systems/3009/SecureBoot" | jq -r

# Use these variables when testing the Redfish endpoint:
export REDFISH_USER="YOUR_USER_API_USER@pve"
export REDFISH_PASS="YOUR_USER_API_USER_TOKEN"
export REDFISH_BASEURL="https://192.168.1.55"
export REDFISH_VMID="501"
export REDFISH_ISOURL="https://download.fedoraproject.org/pub/fedora/linux/releases/42/Workstation/x86_64/iso/Fedora-Workstation-Live-42-1.1.x86_64.iso"

# Example via curl:
# curl -k -X POST -u "${REDFISH_USER}:${REDFISH_PASS}" \
#   -H "Content-Type: application/json" \
#   -d '{"ResetType": "On"}' \
#   "${REDFISH_BASEURL}/redfish/v1/Systems/${REDFISH_VMID}/Actions/ComputerSystem.Reset" | jq -r